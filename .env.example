# --- Server ---
PORT=5001
NODE_ENV=development
CLIENT_URL=*
JWT_SECRET=change-me

# --- MongoDB (multi-tenant) ---
# Single cluster/server URI. Do NOT include a database name — the app selects
# the control DB and per-tenant DBs itself via useDb().
MONGODB_URI=mongodb://127.0.0.1:27017
# Control DB holding the `projects` tenant registry
CONTROL_DB_NAME=Universal_Control
# Fallback tenant for requests without a project code (transition period) and
# for scripts/socket auth running outside a request context
DEFAULT_PROJECT_CODE=RET5677
DEFAULT_DB_NAME=Pagariya_DB

# --- Rate limiting ---
RATE_LIMIT_SKIP_IPS=

# --- SMS (per-tenant overrides move to the project registry over time) ---
SMS_BASE_URL=
SMS_USER_ID=
SMS_PASSWORD=
SMS_SENDER_ID=
SMS_CLIENT_NAME=
SMS_DEFAULT_OTP=

# --- Razorpay (default tenant; per-tenant keys live in the project registry) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Firebase (push notifications) ---
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# --- Cloudinary (media) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
